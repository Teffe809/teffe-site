{
  "name": "teffe-power-bsi",
  "version": "1.0.0",
  "description": "Teffe Power — Badge/PIN System Interface Server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "validate:vehicle": "node scripts/run-capability-validation.js",
    "validate:compatibility": "node scripts/run-vehicle-compatibility-validation.js",
    "validate:stock": "node scripts/run-stock-availability-validation.js",
    "validate:dke": "node scripts/run-domain-knowledge-validation.js",
    "validate:service": "node scripts/run-service-intelligence-validation.js",
    "validate:recommendation": "node scripts/run-recommendation-validation.js",
    "validate:budget": "node scripts/run-budget-intelligence-validation.js",
    "validate:contracts": "node scripts/run-shared-domain-contracts-validation.js",
    "validate:pricing": "node scripts/run-pricing-intelligence-validation.js",
    "validate:decision": "node scripts/run-decision-intelligence-validation.js",
    "validate:decision-rules": "node scripts/run-decision-rules-validation.js",
    "validate:libraries": "node scripts/run-library-registry-validation.js",
    "validate:sales": "node scripts/run-sales-intelligence-validation.js",
    "validate:autoparts-flow": "node scripts/run-autoparts-full-sales-flow-validation.js",
    "validate:tenants": "node scripts/run-tenant-specialization-validation.js",
    "validate:communication": "node scripts/run-communication-gateway-validation.js",
    "validate:dispatcher": "node scripts/run-workflow-dispatcher-validation.js"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2"
  }
}
